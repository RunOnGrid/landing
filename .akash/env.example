# Akash Wallet Configuration
# This file will be automatically generated by setup-wallet.sh
# Copy this file to .env and fill in your values if needed

# Wallet Configuration (automatically filled by setup-wallet.sh)
AKASH_KEY_NAME=your-wallet-name
AKASH_KEYRING_BACKEND=os

# Network Configuration
AKASH_CHAIN_ID=akashnet-2
AKASH_NODE=https://rpc.akashnet.net:443

# Wallet Info (automatically filled)
AKASH_WALLET_ADDRESS=akash1...

# Application Environment Variables (optional)
# Uncomment and set these if you want to configure SMTP for contact forms

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=true
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_TO=contact@gridcloud.com

# Nginx Configuration (usually don't need to change)
# NGINX_PORT=80
# CORS_ORIGIN=*
# CACHE_MAX_AGE=31536000
